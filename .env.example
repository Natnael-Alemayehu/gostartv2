# gostartv2 — Environment Variables Template
# Copy to .env and adjust values for your environment.
# .env is gitignored and must never be committed with real secrets.

# ─── Application ───────────────────────────────────────────────────────────
# Application environment: local, development, staging, production, test
# In production: JWT_SECRET becomes required, CORS wildcard is forbidden
APP_ENV=local

# HTTP port the server listens on
PORT=8080

# ─── Database ──────────────────────────────────────────────────────────────
# DB_HOST: use "localhost" for local dev, "psql_bp" for docker compose
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gostartv2
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MAX_IDLE=5

# ─── JWT ───────────────────────────────────────────────────────────────────
# JWT_SECRET: required in production (APP_ENV=production). Use a random
# string of at least 32 bytes. Generate one with:
#   openssl rand -base64 32
JWT_SECRET=

# Access token lifetime (short-lived, e.g. 15m)
JWT_ACCESS_TTL=15m

# Refresh token lifetime (e.g. 168h = 7 days)
JWT_REFRESH_TTL=168h

# JWT issuer claim
JWT_ISSUER=gostartv2

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. "*" is forbidden in production.
CORS_ALLOWED_ORIGINS=*

# Whether to allow credentials (cookies) in CORS. Must be false when
# origins is "*".
CORS_ALLOW_CREDENTIALS=false
